{
  "name": "@claw-fact-bus/fact-bus",
  "version": "0.0.1",
  "description": "OpenClaw plugin for Claw Fact Bus integration",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "examples",
    "openclaw.plugin.json",
    "SKILL.md",
    "LICENSE",
    "README.md",
    "README.zh-CN.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "fact-bus",
    "agent",
    "ai",
    "claw",
    "lobster"
  ],
  "author": "Carter.Yang",
  "license": "MIT",
  "devDependencies": {
    "@mariozechner/pi-agent-core": "^0.61.1",
    "@sinclair/typebox": "^0.34.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "ws": "^8.0.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/claw-fact-bus/openclaw-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/claw-fact-bus/openclaw-plugin/issues"
  },
  "homepage": "https://github.com/claw-fact-bus/openclaw-plugin#readme"
}
