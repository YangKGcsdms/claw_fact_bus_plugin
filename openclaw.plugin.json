{
  "id": "fact-bus",
  "name": "Claw Fact Bus Plugin",
  "description": "Integrates OpenClaw with Claw Fact Bus for fact-driven agent coordination",
  "version": "1.0.0",
  "contracts": {
    "tools": [
      "fact_bus_sense",
      "fact_bus_publish",
      "fact_bus_query",
      "fact_bus_claim",
      "fact_bus_release",
      "fact_bus_resolve",
      "fact_bus_validate",
      "fact_bus_get_schema"
    ]
  },
  "skills": ["."],
  "uiHints": {
    "busUrl": {
      "label": "Fact Bus URL",
      "help": "The URL of the Claw Fact Bus server",
      "placeholder": "http://localhost:8080"
    },
    "clawName": {
      "label": "Claw Name",
      "help": "Unique identifier for this Claw agent"
    },
    "clawDescription": {
      "label": "Claw Description",
      "help": "Description of this Claw's capabilities"
    },
    "capabilityOffer": {
      "label": "Capabilities Offered",
      "help": "List of capabilities this Claw can provide"
    },
    "domainInterests": {
      "label": "Domain Interests",
      "help": "List of domains this Claw is interested in"
    },
    "factTypePatterns": {
      "label": "Fact Type Patterns",
      "help": "Glob patterns for fact types to subscribe to (e.g., 'code.*.needed')"
    },
    "semanticKinds": {
      "label": "Semantic kinds filter",
      "help": "Only subscribe to these semantic kinds (empty = all)"
    },
    "minEpistemicRank": {
      "label": "Min epistemic rank",
      "help": "Minimum trust rank for facts (-3 to 2)"
    },
    "minConfidence": {
      "label": "Min confidence",
      "help": "Minimum publisher confidence 0-1"
    },
    "subjectKeyPatterns": {
      "label": "Subject key patterns",
      "help": "Glob patterns for subject_key filtering"
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "busUrl": {
        "type": "string",
        "default": "http://localhost:8080",
        "description": "Fact Bus server URL"
      },
      "clawName": {
        "type": "string",
        "description": "Name identifier for this Claw"
      },
      "clawDescription": {
        "type": "string",
        "description": "Description of this Claw's purpose"
      },
      "capabilityOffer": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Capabilities this Claw offers"
      },
      "domainInterests": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Domains this Claw is interested in"
      },
      "factTypePatterns": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Fact type patterns to subscribe"
      },
      "priorityRange": {
        "type": "array",
        "items": { "type": "number" },
        "minItems": 2,
        "maxItems": 2,
        "description": "Priority range [low, high] for WebSocket filter (0-7)"
      },
      "modes": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": ["exclusive", "broadcast"]
        },
        "description": "Fact delivery modes to accept"
      },
      "semanticKinds": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": [
            "observation",
            "assertion",
            "request",
            "resolution",
            "correction",
            "signal"
          ]
        },
        "description": "Semantic kinds to subscribe (empty = all)"
      },
      "minEpistemicRank": {
        "type": "number",
        "default": -3,
        "description": "Minimum epistemic rank for subscription filter"
      },
      "minConfidence": {
        "type": "number",
        "default": 0,
        "minimum": 0,
        "maximum": 1,
        "description": "Minimum confidence for subscription filter"
      },
      "subjectKeyPatterns": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Glob patterns for subject_key"
      },
      "autoReconnect": {
        "type": "boolean",
        "default": true,
        "description": "Auto-reconnect WebSocket on disconnect"
      },
      "reconnectInterval": {
        "type": "number",
        "default": 5000,
        "description": "Reconnect interval in milliseconds"
      }
    },
    "required": []
  }
}
